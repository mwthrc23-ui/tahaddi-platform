{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs",
      "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
      "buildCommand": "cd ../.. && pnpm --filter @tahaddi/contracts build && pnpm --filter @tahaddi/database build && pnpm --filter @tahaddi/web build"
    },
    "realtime": {
      "root": "apps/realtime",
      "entrypoint": "vercel-entry.cjs",
      "framework": "nestjs",
      "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
      "buildCommand": "cd ../.. && pnpm --filter @tahaddi/contracts build && pnpm --filter @tahaddi/database build && pnpm --filter @tahaddi/realtime build"
    }
  },
  "rewrites": [
    {
      "source": "/socket.io/(.*)",
      "destination": {
        "service": "realtime"
      }
    },
    {
      "source": "/realtime/(.*)",
      "destination": {
        "service": "realtime"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ]
}
