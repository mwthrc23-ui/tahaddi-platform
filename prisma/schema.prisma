generator client {
  provider = "prisma-client"
  output   = "../packages/database/src/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum QuestionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model User {
  id            String     @id @default(cuid())
  name          String?    @db.VarChar(120)
  email         String?    @unique @db.VarChar(320)
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  tokenVersion  Int        @default(0)
  lastLoginAt   DateTime?
  suspendedAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  questions     Question[]
  quizzes       Quiz[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model Question {
  id          String             @id @default(cuid())
  ownerId     String
  type        QuestionType       @default(MULTIPLE_CHOICE)
  status      QuestionStatus     @default(DRAFT)
  difficulty  QuestionDifficulty @default(MEDIUM)
  prompt      String             @db.VarChar(1000)
  explanation String?            @db.VarChar(2000)
  category    String?            @db.VarChar(120)
  source      String?            @db.VarChar(500)
  timeLimit   Int                @default(20)
  basePoints  Int                @default(1000)
  archivedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  owner       User               @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  options     QuestionOption[]
  quizzes     QuizQuestion[]

  @@index([ownerId, status])
  @@index([ownerId, updatedAt])
  @@index([category, status])
}

model Quiz {
  id          String         @id @default(cuid())
  title       String         @db.VarChar(160)
  description String?        @db.VarChar(1000)
  ownerId     String
  roomCode    String         @unique @db.VarChar(8)
  isPublic    Boolean        @default(false)
  status      QuizStatus     @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  questions   QuizQuestion[]

  @@index([ownerId, status])
  @@index([isPublic, status])
  @@index([createdAt])
}

model QuizQuestion {
  quizId     String
  questionId String
  position   Int
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@id([quizId, questionId])
  @@unique([quizId, position])
  @@index([questionId])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  position   Int
  text       String   @db.VarChar(500)
  isCorrect  Boolean  @default(false)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, position])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  @db.VarChar(64)
  provider          String  @db.VarChar(64)
  providerAccountId String  @db.VarChar(191)
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String   @db.VarChar(320)
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String   @db.VarChar(120)
  bio         String?  @db.VarChar(500)
  locale      String   @default("ar") @db.VarChar(12)
  timezone    String   @default("Asia/Riyadh") @db.VarChar(64)
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([displayName])
}
