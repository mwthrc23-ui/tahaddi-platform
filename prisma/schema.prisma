generator client {
  provider = "prisma-client"
  output   = "../packages/database/src/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
}

model User {
  id            String      @id @default(cuid())
  name          String?     @db.VarChar(120)
  email         String?     @unique @db.VarChar(320)
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole    @default(USER)
  status        UserStatus  @default(ACTIVE)
  lastLoginAt   DateTime?
  suspendedAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  accounts      Account[]
  sessions      Session[]
  profile       Profile?

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  @db.VarChar(64)
  provider          String  @db.VarChar(64)
  providerAccountId String  @db.VarChar(191)
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String   @db.VarChar(320)
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String   @db.VarChar(120)
  bio         String?  @db.VarChar(500)
  locale      String   @default("ar") @db.VarChar(12)
  timezone    String   @default("Asia/Riyadh") @db.VarChar(64)
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([displayName])
}
